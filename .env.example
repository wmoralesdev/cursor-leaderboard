# Neon Postgres (pooled connection string recommended)
# Project: cursor-leaderboard — create via Neon console or MCP, then paste URL here
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Minutes between refresh scrapes for the same handle (default: 15)
SCRAPE_COOLDOWN_MINUTES=15

# Optional custom User-Agent when fetching cursor.com profiles
# SCRAPE_USER_AGENT="cursor-leaderboard/1.0"

# Public site URL for canonical links, Open Graph, sitemap, and robots (no trailing slash)
# VITE_SITE_URL="https://your-production-domain.com"
