// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScrapeStatus {
  ok
  not_found
  parse_error
}

model LeaderboardEntry {
  id                 String       @id @default(cuid())
  handle             String       @unique
  country            String       @db.Char(2)
  displayName        String?
  profileUrl         String
  isAmbassador       Boolean      @default(false)
  joinedDaysAgo      Int?
  agentsTotal        Int          @default(0)
  agentsLocal        Int          @default(0)
  agentsCloud        Int          @default(0)
  currentStreakDays  Int          @default(0)
  longestStreakDays  Int          @default(0)
  longestAgentHours  Float        @default(0)
  tokensTotal        BigInt       @default(0)
  topModels          Json         @default("[]")
  scrapeStatus       ScrapeStatus @default(parse_error)
  scrapeError        String?
  scrapedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([agentsTotal(sort: Desc)])
  @@index([country, agentsTotal(sort: Desc)])
  @@index([tokensTotal(sort: Desc)])
  @@index([currentStreakDays(sort: Desc)])
  @@index([longestStreakDays(sort: Desc)])
  @@index([joinedDaysAgo(sort: Desc)])
  @@index([longestAgentHours(sort: Desc)])
  @@index([scrapedAt])
}

model CountryDetailCache {
  country          String   @id @db.Char(2)
  profileCount     Int
  globalRank       Int?
  topModel         String?
  avgAgentsTotal   Float
  avgCloudShare    Float
  maxLongestStreak Int
  topBuilders      Json
  computedAt       DateTime
}

model ModelStatsCache {
  model            String   @id
  profileCount     Int
  topCountries     Json
  topBuilders      Json
  avgAgentsTotal   Float
  avgCurrentStreak Float
  computedAt       DateTime
}

model LeaderboardStatsCache {
  id               String   @id @default("global")
  profileCount     Int
  agentsSum        Int
  tokensSum        BigInt
  currentStreakSum Int
  longestStreakSum Int
  computedAt       DateTime
}

model CountryStatsCache {
  id           String   @id @default("global")
  countryCount Int
  topModel     String?
  computedAt   DateTime
}
